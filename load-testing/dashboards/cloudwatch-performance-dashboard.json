          [".", ".", ".", ".", ".", ".", ".", "chat-worker", { "stat": "Average", "label": "Chat Worker" }],
          [".", ".", ".", ".", ".", ".", ".", "asset-worker", { "stat": "Average", "label": "Asset Worker" }],
          [".", ".", ".", ".", ".", ".", ".", "frontend-worker", { "stat": "Average", "label": "Frontend Worker" }]
        ],
        "period": 60,
        "yAxis": {
          "left": { "min": 0, "max": 100 }
        },
        "annotations": {
