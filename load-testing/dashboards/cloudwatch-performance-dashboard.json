        "metrics": [
          ["ContainerInsights", "pod_memory_utilization", "ClusterName", "eventxgames", "Namespace", "eventxgames", "PodName", "api-worker", { "stat": "Average", "label": "API Worker" }],
          [".", ".", ".", ".", ".", ".", ".", "game-worker", { "stat": "Average", "label": "Game Worker" }],
          [".", ".", ".", ".", ".", ".", ".", "chat-worker", { "stat": "Average", "label": "Chat Worker" }],
          [".", ".", ".", ".", ".", ".", ".", "asset-worker", { "stat": "Average", "label": "Asset Worker" }],
          [".", ".", ".", ".", ".", ".", ".", "frontend-worker", { "stat": "Average", "label": "Frontend Worker" }]
        ],
        "period": 60,
        "yAxis": {
          "left": { "min": 0, "max": 100 }
        },
        "annotations": {
          "horizontal": [
            { "color": "#ff7f0e", "label": "Warning (75%)", "value": 75 },
            { "color": "#d62728", "label": "Critical (90%)", "value": 90 }
          ]
        }
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 35,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "EKS - Running Pod Count",
        "view": "timeSeries",
        "stacked": true,
        "region": "us-east-1",
        "metrics": [
          ["ContainerInsights", "pod_number_of_running_pods", "ClusterName", "eventxgames", "Namespace", "eventxgames", { "stat": "Average" }]
        ],
        "period": 60
      }
    },
    {
      "type": "metric",
      "x": 8,
      "y": 35,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "EKS - Node CPU & Memory",
        "view": "timeSeries",
        "stacked": false,
        "region": "us-east-1",
        "metrics": [
          ["ContainerInsights", "node_cpu_utilization", "ClusterName", "eventxgames", { "stat": "Average", "label": "Node CPU %" }],
          [".", "node_memory_utilization", ".", ".", { "stat": "Average", "label": "Node Memory %" }]
        ],
        "period": 60,
        "yAxis": {
          "left": { "min": 0, "max": 100 }
        }
      }
    },
    {
      "type": "metric",
      "x": 16,
      "y": 35,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "EKS - Network I/O",
        "view": "timeSeries",
        "stacked": false,
        "region": "us-east-1",
        "metrics": [
          ["ContainerInsights", "pod_network_rx_bytes", "ClusterName", "eventxgames", "Namespace", "eventxgames", { "stat": "Sum", "label": "RX Bytes" }],
          [".", "pod_network_tx_bytes", ".", ".", ".", ".", { "stat": "Sum", "label": "TX Bytes" }]
        ],
        "period": 60
      }
    },
    {
      "type": "text",
      "x": 0,
      "y": 41,
      "width": 24,
      "height": 1,
      "properties": {
        "markdown": "## WebSocket Metrics"
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 42,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "WebSocket - Active Connections",
        "view": "timeSeries",
        "stacked": false,
        "region": "us-east-1",
        "metrics": [
          ["EventXGames", "WebSocketConnections", "Service", "chat-worker", { "stat": "Maximum", "label": "Active Connections" }]
        ],
        "period": 60,
        "annotations": {
          "horizontal": [
            { "color": "#2ca02c", "label": "Baseline (50K)", "value": 50000 },
            { "color": "#ff7f0e", "label": "Peak Target (100K)", "value": 100000 }
          ]
        }
      }
    },
    {
      "type": "metric",
      "x": 8,
      "y": 42,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "WebSocket - Message Throughput",
        "view": "timeSeries",
        "stacked": false,
        "region": "us-east-1",
        "metrics": [
          ["EventXGames", "WebSocketMessagesReceived", "Service", "chat-worker", { "stat": "Sum", "label": "Messages Received" }],
          [".", "WebSocketMessagesSent", ".", ".", { "stat": "Sum", "label": "Messages Sent" }]
        ],
        "period": 60
      }
    },
    {
      "type": "metric",
      "x": 16,
      "y": 42,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "WebSocket - Latency & Errors",
        "view": "timeSeries",
        "stacked": false,
        "region": "us-east-1",
        "metrics": [
          ["EventXGames", "WebSocketMessageLatency", "Service", "chat-worker", { "stat": "p95", "label": "Message Latency P95 (ms)" }],
          [".", "WebSocketErrors", ".", ".", { "stat": "Sum", "label": "Errors", "yAxis": "right" }]
        ],
        "period": 60,
        "yAxis": {
          "left": { "min": 0, "max": 200, "label": "Latency (ms)" },
          "right": { "min": 0, "label": "Error Count" }
        }
      }
    }
  ]
}
